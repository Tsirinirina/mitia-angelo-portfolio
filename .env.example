# Configuration du formulaire de contact (envoi d'email via SMTP)
# Copiez ce fichier en ".env" et renseignez vos valeurs.
# NE COMMITEZ JAMAIS le vrai ".env" (déjà ignoré par .gitignore).

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false

# Compte qui ENVOIE les emails (Gmail : utilisez un "mot de passe d'application")
SMTP_USER=votre-compte-envoi@gmail.com
SMTP_PASS=mot-de-passe-application

# Adresse qui REÇOIT les messages du formulaire
CONTACT_EMAIL=rajaonarisonmitialeonangelo@gmail.com
